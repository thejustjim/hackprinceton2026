# GreenChain backend — environment template
# Copy to `.env` and fill in your own keys. Never commit `.env`.

# Dedalus Labs LLM gateway key — https://dedaluslabs.ai
DEDALUS_API_KEY=

# Anthropic API key — Dedalus passes this through to Claude
ANTHROPIC_API_KEY=

# Brave Search API key (free tier: 2k queries/month, 1 req/sec)
# https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# Optional: override the default model. Leave blank for Sonnet 4.6.
# GREENCHAIN_MODEL=anthropic/claude-sonnet-4-6

# K2 Think API key for prompt-driven scenario edits.
# https://api.k2think.ai
K2THINK_API_KEY=

# Optional: override the K2 Think base URL. Defaults to https://api.k2think.ai/v1
# K2THINK_BASE_URL=https://api.k2think.ai/v1

# Optional: override the K2 Think model name used for scenario edits.
# K2THINK_MODEL=MBZUAI-IFM/K2-Think-v2

# Optional: override the ML model directory. Leave blank to use the
# vendored copy at greenchain/ml_runtime/.
# ML_ROOT=

# Optional: override the SQLite audit DB path. Defaults to backend/greenchain.db.
# DB_PATH=

# Optional: if Dedalus/Brave fail, return synthetic manufacturers instead of HTTP 502.
# Leave unset or 0 in development so you see the real error instead of mock data.
# GREENCHAIN_ALLOW_MOCK_COMPONENT_SEARCH=1

# Optional: route fetch_url HTTP egress through a provisioned Dedalus Machine
# (KVM-isolated Linux VM). Requires DEDALUS_API_KEY; adds ~3-5s to backend
# startup while the Machine boots. Falls back to local httpx on any error.
# GREENCHAIN_USE_DEDALUS_MACHINE=1
